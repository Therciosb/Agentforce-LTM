# -----------------------------------------------------------------------------
# LTM Agent Checkpoint (Deterministic Save Checkpoints)
# -----------------------------------------------------------------------------
# Purpose
# - Load context once at startup
# - Let the LLM capture memory changes during conversation
# - Persist memory deterministically after reasoning when context is dirty
# - Persist once more in finalization as a safety checkpoint
# -----------------------------------------------------------------------------

# Global assistant identity and default user-visible system messages.
system:
    instructions: |
        You are a highly personalized AI assistant for products and services.
        Adapt your tone and depth to the user's communication style and service tier.
    messages:
        welcome: "Accessing your profile..."
        error: "Sorry, it looks like something has gone wrong."

# Agentforce metadata identity for this bundle in the org.
config:
    developer_name: "ltm_agent_checkpoint"
    default_agent_user: "ltm_agent@00dky00000gxhj51777765750.ext"
    agent_label: "ltm-agent-checkpoint"
    description: "LTM agent with deterministic checkpoint saves during conversation."

variables:
    EndUserId: linked string
        source: @MessagingSession.MessagingEndUserId
        description: "Messaging end user id from the session."
    RoutableId: linked string
        source: @MessagingSession.Id
        description: "Messaging session id."

    
    
    # ContactId is mutable by design in this educational project so it can be
    # hardcoded for testing and later replaced by linked context in production.
    # Available CRM test Contact IDs:
    # - 003KY00000KNAGpYAP
    # - 003KY00000KNAGqYAP
    # - 003KY00000KNAGrYAP
    ContactId: mutable string = "003KY00000KNAGqYAP"
        description: "Resolved contact id used by Apex actions."
    context_loaded: mutable boolean = False
        description: "Prevents duplicate context fetch in the same session."
    context_dirty: mutable boolean = False
        description: "True when memory values changed and must be checkpoint-saved."

    # Formatted string from LoadAgentMemory Apex.
    agent_memory: mutable string = ""
        description: "Formatted merge of memory fields for personalization."

    # Working memory values used for deterministic save checkpoints.
    memory_summary: mutable string = ""
        description: "Current long-term summary to persist."
    memory_goal: mutable string = ""
        description: "Current pending goal to persist."
    memory_has_issue: mutable boolean = False
        description: "Current unresolved issue flag to persist."
    memory_style: mutable string = "Detailed"
        description: "Current communication style to persist."

# Locale constraints enforced for all responses.
language:
    default_locale: "en_US"
    additional_locales: ""
    all_additional_locales: False

topic general_assistance:
    label: "General Assistance"
    description: "Handles all user conversations and checkpoint memory updates."

    # Action contracts available inside this topic.
    actions:
        save_user_context:
            description: "Saves Agent_Context__c using extracted memory fields."
            inputs:
                contactId: string
                    description: "The user's Contact ID."
                newSummary: string
                    description: "Add 1-3 sentences about user responses and assistant recommendations."
                newGoal: string
                    description: "Unfinished goal from this conversation, or empty string."
                hasIssue: boolean
                    description: "True if the user still has an unresolved issue."
                newStyle: string
                    description: "Preferred communication style inferred from this conversation."
            outputs:
                success: boolean
                    description: "Whether save succeeded."
            target: "apex://SaveAgentContext"

    # Main conversational instructions:
    # - personalize from loaded memory (agent_memory)
    # - capture a cumulative conversation summary every turn
    # - route to escalation/finalization when explicitly requested
    reasoning:
        instructions: ->
            | Here is your past context. Use it for personalization:
            | {!@variables.agent_memory}
            | Also use working memory: last summary = {!@variables.memory_summary}, unresolved issue = {!@variables.memory_has_issue}, pending goal = {!@variables.memory_goal}.
            | Address the user by name when greeting or acknowledging. If the name is formatted like "<person name> - Agent Context", use only the person name portion.
            | If unresolved issue is true, acknowledge it and ask whether it was resolved. If there is a pending goal, ask if the user wants to continue it.
            | In EVERY turn, call {!@actions.capture_memory_update} exactly once.
            | Build memory_summary as a cumulative running summary of the whole conversation.
            | Append this turn using both sides:
            | - User response/input from this turn.
            | - Assistant recommendation/comment from this turn.
            | Keep memory_summary concise but complete across turns; do not overwrite prior context with only the latest turn.
            | When calling capture_memory_update, always provide memory_summary, memory_goal, and memory_has_issue.
            | If the user explicitly asks to transfer to a live agent, use {!@actions.escalate_to_human}.
            | If the user indicates they are done or says goodbye, use {!@actions.go_to_finalization}.

        # LLM-callable tools:
        actions:
            capture_memory_update: @utils.setVariables
                description: "Capture cumulative conversation summary plus current memory status and mark context dirty."
                with memory_summary=...
                with memory_goal=...
                with memory_has_issue=...
                with context_dirty=True
            escalate_to_human: @utils.escalate
                description: "Transfer to a live human agent on explicit request."
            go_to_finalization: @utils.transition to @topic.finalization
                description: "Use when user is done or there is an indication of ending the conversation."

    # Deterministic checkpoint logic that runs every turn:
    # 1) Fill any missing working-memory fields from loaded values (already set at startup).
    # 2) Persist only when memory was marked dirty during reasoning.
    after_reasoning:
        if @variables.context_dirty == True:
            run @actions.save_user_context
                with contactId=@variables.ContactId
                with newSummary=@variables.memory_summary
                with newGoal=@variables.memory_goal
                with hasIssue=@variables.memory_has_issue
                with newStyle=@variables.memory_style
                set @variables.context_dirty=False

topic finalization:
    label: "Finalization"
    description: "Persists memory one last time and ends conversation."

    actions:
        save_user_context:
            description: "Saves Agent_Context__c using extracted memory fields."
            inputs:
                contactId: string
                    description: "The user's Contact ID."
                newSummary: string
                    description: "Detailed 3-5 sentences summary considering previous facts."
                newGoal: string
                    description: "Unfinished goal from this conversation, or empty string."
                hasIssue: boolean
                    description: "True if the user still has an unresolved issue."
                newStyle: string
                    description: "Preferred communication style inferred from this conversation."
            outputs:
                success: boolean
                    description: "Whether save succeeded."
            target: "apex://SaveAgentContext"

    # Deterministic final save path:
    reasoning:
        instructions: ->
            run @actions.save_user_context
                with contactId=@variables.ContactId
                with newSummary=@variables.memory_summary
                with newGoal=@variables.memory_goal
                with hasIssue=@variables.memory_has_issue
                with newStyle=@variables.memory_style
                set @variables.context_dirty=False

            | Give a warm goodbye and confirm context is saved.

# NOTE: Keep start_agent as the LAST topic block in this file.
start_agent topic_selector:
    label: "Entry Point"
    description: "Loads context once, then routes to checkpoint assistance."

    actions:
        load_user_memory_checkpoint:
            description: "Fetches the user's long-term context from the database."
            inputs:
                contactId: string
                    description: "The user's Contact ID."
            outputs:
                agentMemory: string
                    description: "Formatted merge of memory fields for personalization."
                memorySummary: string
                    description: "Last topic summary from loaded context."
                memoryGoal: string
                    description: "Pending goal from loaded context."
                hasIssue: boolean
                    description: "Unresolved issue flag from loaded context."
                memoryStyle: string
                    description: "Communication style from loaded context."
            target: "apex://LoadAgentMemory"

    # Startup sequence:
    # - load context once when ContactId exists
    # - initialize working memory from Apex outputs
    # - mark loaded to avoid duplicate fetches
    # - hand off to general assistance
    reasoning:
        instructions: ->
            if @variables.context_loaded == False and @variables.ContactId and @variables.ContactId != "":
                run @actions.load_user_memory_checkpoint
                    with contactId=@variables.ContactId
                    set @variables.agent_memory=@outputs.agentMemory
                    set @variables.memory_summary=@outputs.memorySummary
                    set @variables.memory_goal=@outputs.memoryGoal
                    set @variables.memory_has_issue=@outputs.hasIssue
                    set @variables.memory_style=@outputs.memoryStyle
                    set @variables.context_loaded=True

            if @variables.context_loaded == False:
                set @variables.context_loaded=True

            transition to @topic.general_assistance
