# -----------------------------------------------------------------------------
# LTM Agent Test (Minimal Object Mapping)
# -----------------------------------------------------------------------------

system:
    instructions: |
        You are a concise assistant for product and service questions.
    messages:
        welcome: "Loading your context..."
        error: "Sorry, something went wrong."

config:
    developer_name: "ltm_agent_test"
    # Replace YOUR_ORG_ID with your org ID (Setup > Company Information)
    default_agent_user: "ltm_agent@YOUR_ORG_ID.ext"
    agent_label: "ltm-agent-test"
    description: "Minimal test agent for object-based memory mapping."

variables:
    ContactId: mutable string = "YOUR_CONTACT_ID"
        description: "Resolved contact id used by flow actions."

    context_loaded: mutable boolean = False
        description: "Prevents duplicate context fetch in the same session."

    agent_memory: mutable string = ""
        description: "Formatted merge of memory fields from flow output."

language:
    default_locale: "en_US"
    additional_locales: ""
    all_additional_locales: False

topic general_assistance:
    label: "General Assistance"
    description: "Simple topic to validate memory access using agent_memory."

    reasoning:
        instructions: ->
            | Here is your past context. Use it for personalization:
            | {!@variables.agent_memory}
            | If unresolved issue is indicated in the context, acknowledge it and ask whether it was resolved. If a pending goal is set, ask if the user wants to continue it.
            | Answer the user's question clearly and briefly.

start_agent topic_selector:
    label: "Entry Point"
    description: "Loads context and routes to assistance."

    actions:
        load_user_memory:
            description: "Fetches Agent_Context__c as formatted string."
            inputs:
                contact_id: string
                    description: "The user's Contact ID."
            outputs:
                agent_memory: string
                    description: "Formatted merge of memory fields for personalization."
            target: "flow://Get_Agent_ContextObject"

    reasoning:
        instructions: ->
            if @variables.context_loaded == False and @variables.ContactId and @variables.ContactId != "":
                run @actions.load_user_memory
                    with contact_id=@variables.ContactId
                    set @variables.agent_memory=@outputs.agent_memory
                    set @variables.context_loaded=True

            if @variables.context_loaded == False:
                set @variables.context_loaded=True

            transition to @topic.general_assistance
