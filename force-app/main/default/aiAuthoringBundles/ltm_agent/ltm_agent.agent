# -----------------------------------------------------------------------------
# LTM Agent (Educational Version)
# -----------------------------------------------------------------------------
# Purpose
# - Demonstrates how to implement long-term memory in Agentforce using:
#   1) Mutable variables for in-session state
#   2) Apex-backed Flow actions for persistent read/write
#   3) Deterministic startup logic before conversational reasoning
#
# High-level flow
# 1) start_agent.topic_selector runs first
# 2) It loads user memory from flow://Get_Agent_ContextObject (once per session)
# 3) It stores the formatted string in agent_memory
# 4) general_assistance personalizes responses from agent_memory
# 5) finalization saves context to flow://Save_Agent_ContextObject
# -----------------------------------------------------------------------------

system:
    # Global behavior instructions for the model.
    # Keep these generic and stable; avoid dynamic template expressions here.
    instructions: |
        You are a highly personalized AI assistant for products and services.
        Adapt your tone and depth to the user's communication style and service tier.
    messages:
        # Initial message shown when the session starts.
        welcome: "Accessing your profile..."
        # Fallback message shown when an unexpected internal error occurs.
        error: "Sorry, it looks like something has gone wrong."

config:
    # Unique API developer name for this agent.
    developer_name: "ltm_agent"
    # Runtime user that executes actions/flows for this agent.
    # Replace YOUR_ORG_ID with your org ID (Setup > Company Information, or: sf org display --json | jq -r '.result.orgId')
    default_agent_user: "ltm_agent@YOUR_ORG_ID.ext"
    # Human-readable label shown in setup UIs.
    agent_label: "ltm-agent"
    # Short functional description.
    description: "Engage with users responding questions regarding products and services"

variables:
    # Linked variables are populated by platform context.
    EndUserId: linked string
        source: @MessagingSession.MessagingEndUserId
        description: "Messaging end user id from the session."
    RoutableId: linked string
        source: @MessagingSession.Id
        description: "Messaging session id."

    # ContactId is mutable by design in this educational project so it can be
    # hardcoded for testing and later replaced by linked context in production.
    # Replace with a Contact ID from your org (create test Contacts first).
    ContactId: mutable string = "YOUR_CONTACT_ID"
        description: "Resolved contact id used by flow actions."

    # Guard flag to prevent repeated memory fetch calls in a single session.
    context_loaded: mutable boolean = False
        description: "Prevents duplicate context fetch in the same session."

    # Formatted string from Get_Agent_ContextObject (LoadAgentMemory Apex).
    agent_memory: mutable string = ""
        description: "Formatted merge of Agent_Context__c fields for profile personalization."

language:
    # Primary language for model responses.
    default_locale: "en_US"
    # Keep additional locales disabled for deterministic educational behavior.
    additional_locales: ""
    all_additional_locales: False

topic general_assistance:
    label: "General Assistance"
    # Main conversational topic after memory initialization.
    description: "Handles all user conversations using stored context."

    reasoning:
        instructions: ->
            | Here is your past context. Use it for personalization:
            | {!@variables.agent_memory}
            | If unresolved issue is indicated in the context, acknowledge prior issues and ask whether they were resolved. If a pending goal is set, ask if the user wants to continue it. Adapt tone to communication style and tier.
            | Assist with products, services, orders, issue resolution, and related questions.
            | If the user explicitly asks to transfer to a live agent, use escalate_to_human.
            | If the user indicates they are done or says goodbye, use go_to_finalization.
        actions:
            # Utility action exposed to the model for explicit human handoff.
            escalate_to_human: @utils.escalate
                description: "Transfer to a live human agent on explicit request."
            # Utility action that transitions to the save-and-goodbye topic.
            go_to_finalization: @utils.transition to @topic.finalization
                description: "Use when user is done and wants to end the conversation."

topic finalization:
    label: "Finalization"
    # Dedicated topic to persist context before ending the chat.
    description: "Summarizes and saves conversation context."

    actions:
        # Flow action for writing long-term memory (Apex-backed).
        save_user_context:
            description: "Saves Agent_Context__c using extracted memory fields."
            inputs:
                contact_id: string
                    description: "The user's Contact ID."
                new_summary: string
                    description: "Concise summary of this conversation."
                new_goal: string
                    description: "Unfinished goal from this conversation, or empty string."
                has_issue: boolean
                    description: "True if the user still has an unresolved issue."
                new_style: string
                    description: "Preferred communication style inferred from this conversation."
            outputs:
                success: boolean
                    description: "Whether save succeeded."
            target: "flow://Save_Agent_ContextObject"

    reasoning:
        instructions: ->
            # Finalization must persist memory through the save tool before goodbye.
            | Before saying goodbye, call {!@actions.save_context_tool} exactly once to persist memory.
            | Generate these values from this conversation and pass all of them when calling save_context_tool: new_summary, new_goal, has_issue, and new_style.
            | Required extraction rules:
            | - new_summary: concise 3-5 sentence summary of what happened in this session.
            | - new_goal: unfinished user goal to continue later, or empty string if none.
            | - has_issue: true only if the user still has unresolved issues at the end of the session.
            | - new_style: communication preference inferred from this session (for example, concise, detailed, formal).
            | Never call save_context_tool with empty arguments. Always include values for all required extracted fields.
            | After the tool returns, give a warm goodbye and confirm context is saved.
        actions:
            # Persist context using LLM-extracted fields.
            save_context_tool: @actions.save_user_context
                description: "Required at session end. Save context with extracted summary, goal, unresolved-issue flag, and communication style."
                with contact_id=@variables.ContactId
                with new_summary=...
                with new_goal=...
                with has_issue=...
                with new_style=...

# NOTE: Keep start_agent as the LAST topic block in this file.
start_agent topic_selector:
    label: "Entry Point"
    # Deterministic memory bootstrap and routing topic.
    description: "Fetches user context and routes to main assistance."

    actions:
        # Read flow action (persistent memory lookup via LoadAgentMemory Apex).
        load_user_memory:
            description: "Fetches the user's long-term context from the database."
            inputs:
                contact_id: string
                    description: "The user's Contact ID."
                variable_name: string
                    description: "Target variable name (default: agent_memory)."
            outputs:
                agent_memory: string
                    description: "Formatted merge of memory fields for personalization."
            target: "flow://Get_Agent_ContextObject"

    reasoning:
        instructions: ->
            # Keep variable mapping inside the run block for deterministic state.
            if @variables.context_loaded == False and @variables.ContactId and @variables.ContactId != "":
                run @actions.load_user_memory
                    with contact_id=@variables.ContactId
                    set @variables.agent_memory=@outputs.agent_memory
                    set @variables.context_loaded=True

            # Fallback simply flips the guard to avoid repeated attempts.
            if @variables.context_loaded == False:
                set @variables.context_loaded=True

            # Deterministic handoff to the main conversation topic.
            transition to @topic.general_assistance
