# Copy to .env and fill in values for local testing.
# .env is gitignored and should never be committed.

# Salesforce org alias (default: my-org)
SF_TARGET_ORG=my-org

# Contact IDs for seed script and API tests (create Contacts in your org first)
SF_CONTACT_1=
SF_CONTACT_2=
SF_CONTACT_3=

# For test-agent-api-with-contact.js (optional; script can use sf org display)
SF_ACCESS_TOKEN=
SF_INSTANCE_URL=
SF_AGENT_ID=
